FACTLENS_RATE_LIMIT_WINDOW_SECONDS=60
FACTLENS_RATE_LIMIT_READ_REQUESTS=240
FACTLENS_RATE_LIMIT_WRITE_REQUESTS=90
FACTLENS_RATE_LIMIT_ANALYZE_REQUESTS=12
