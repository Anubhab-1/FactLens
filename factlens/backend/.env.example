FACTLENS_LLM_PROVIDER=auto
NVIDIA_API_KEY=your_nvidia_api_key
GOOGLE_API_KEY=your_google_api_key
OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key
SERPER_API_KEY=your_serper_api_key
SERPAPI_API_KEY=your_serpapi_api_key
GOOGLE_CSE_ID=your_google_custom_search_engine_id
FACTLENS_DATABASE_URL=
FACTLENS_EXTRACTOR_MODEL=
FACTLENS_RETRIEVER_MODEL=
FACTLENS_VERIFIER_MODEL=
FACTLENS_TEXT_DETECTOR_MODEL=
FACTLENS_MEDIA_DETECTOR_MODEL=
FACTLENS_MEDIA_DETECTOR_MODE=auto
FACTLENS_MEDIA_CLASSIFIER_URL=
FACTLENS_MEDIA_CLASSIFIER_API_KEY=
FACTLENS_MEDIA_CLASSIFIER_AUTH_HEADER=Authorization
FACTLENS_MEDIA_CLASSIFIER_TIMEOUT_SECONDS=20
FACTLENS_BROWSER_RENDER_WAIT_SECONDS=2.5
FACTLENS_BROWSER_TIMEOUT_SECONDS=25
FACTLENS_PUBLIC_SHARE_ENABLED=true
FACTLENS_LEGACY_PUBLIC_REPORTS=true
